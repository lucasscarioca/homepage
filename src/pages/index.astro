---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<main class="mx-auto min-h-screen w-full max-w-3xl px-6 py-16 sm:px-8 sm:py-24">
		<div class="pointer-events-none fixed inset-0 opacity-30">
			<div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(143,183,255,0.18),transparent_26%)]"></div>
			<div class="absolute inset-0 bg-[radial-gradient(circle_at_bottom_left,rgba(255,255,255,0.06),transparent_24%)]"></div>
		</div>

		<div class="relative">
			<header class="flex items-start justify-between gap-6">
				<div class="flex items-center gap-4">
					<div class="rounded-full bg-[linear-gradient(135deg,rgba(143,183,255,0.3),rgba(255,255,255,0.08))] p-[1px] shadow-[0_0_40px_rgba(143,183,255,0.12)]">
						<img
							class="h-14 w-14 rounded-full object-cover"
							src="https://avatars.githubusercontent.com/u/70043515?v=4"
							alt="Lucas Carioca"
						/>
					</div>
					<div>
						<p class="text-[15px] font-semibold tracking-[-0.02em] text-[color:var(--color-ink)]">
							Lucas Carioca
						</p>
						<p class="mt-1 text-sm text-[color:var(--color-ink-soft)]">
							AI Engineer
						</p>
					</div>
				</div>

				<div class="flex flex-wrap items-center justify-end gap-4 text-[color:var(--color-ink-soft)]">
					<a
						class="transition hover:text-[color:var(--color-ink)]"
						href="mailto:lucascarioca97@gmail.com"
						aria-label="Email Lucas Carioca"
					>
						<svg class="h-[18px] w-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
							<rect x="3" y="5" width="18" height="14" rx="2"></rect>
							<path d="m4 7 8 6 8-6"></path>
						</svg>
					</a>
					<a
						class="transition hover:text-[color:var(--color-ink)]"
						href="https://github.com/lucasscarioca"
						target="_blank"
						rel="noreferrer"
						aria-label="Lucas Carioca GitHub"
					>
						<svg class="h-[18px] w-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
							<path d="M9 19c-4.3 1.4-4.3-2.4-6-3"></path>
							<path d="M15 22v-3.9a3.4 3.4 0 0 0-.9-2.6c3 0 6.2-1.5 6.2-7A5.4 5.4 0 0 0 18.7 5 5 5 0 0 0 18.6 1S17.4.7 15 2.3a13.4 13.4 0 0 0-6 0C6.6.7 5.4 1 5.4 1A5 5 0 0 0 5.3 5a5.4 5.4 0 0 0-1.6 3.5c0 5.5 3.2 7 6.2 7a3.4 3.4 0 0 0-.9 2.6V22"></path>
						</svg>
					</a>
					<a
						class="transition hover:text-[color:var(--color-ink)]"
						href="https://www.linkedin.com/in/lucas-carioca/"
						target="_blank"
						rel="noreferrer"
						aria-label="Lucas Carioca LinkedIn"
					>
						<svg class="h-[18px] w-[18px]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
							<path d="M6.94 8.5H3.56V20h3.38V8.5Zm.22-3.56c0-1.06-.8-1.94-1.91-1.94-1.1 0-1.91.88-1.91 1.94 0 1.04.79 1.9 1.87 1.9h.02c1.13 0 1.93-.86 1.93-1.9ZM20.44 13.01c0-3.46-1.85-5.07-4.33-5.07-2 0-2.89 1.1-3.39 1.87V8.5H9.34c.04.87 0 11.5 0 11.5h3.38v-6.42c0-.34.02-.68.13-.92.27-.68.9-1.39 1.96-1.39 1.38 0 1.94 1.05 1.94 2.59V20h3.38v-6.99Z"></path>
						</svg>
					</a>
				</div>
			</header>

			<section class="mt-18 sm:mt-20">
				<p class="max-w-2xl text-[1.05rem] leading-8 font-medium text-[color:var(--color-ink)] sm:text-[1.1rem]">
					I build AI products for companies that want useful agents, better workflows, and
					real systems people can actually rely on.
				</p>
			</section>

			<section class="mt-8 max-w-2xl space-y-4 text-[15px] leading-8 text-[color:var(--color-ink-soft)]">
				<p>
					My work sits between product thinking and systems engineering: designing LLM-powered
					experiences, agent workflows, and the backend infrastructure behind chat,
					automation, integrations, and messaging.
				</p>
				<p>
					I am most useful when a team has a strong idea for an AI product and needs someone to
					turn it into a clear, working experience from prototype to production. If that sounds
					like your project,
					<a
						class="border-b border-transparent text-[color:var(--color-ink)] transition hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)]"
						href="mailto:lucascarioca97@gmail.com"
					>
						get in touch
					</a>.
				</p>
			</section>

			<section class="mt-12 max-w-2xl">
				<p class="text-xs uppercase tracking-[0.28em] text-[color:var(--color-accent)]">What I do</p>
				<ul class="mt-5 space-y-3 text-[15px] leading-8 text-[color:var(--color-ink-soft)]">
					<li class="flex items-start gap-3">
						<span class="mt-3 h-1.5 w-1.5 shrink-0 rounded-full bg-[color:var(--color-accent)]"></span>
						<span>Build AI agents, chat experiences, and automation workflows around real business needs.</span>
					</li>
					<li class="flex items-start gap-3">
						<span class="mt-3 h-1.5 w-1.5 shrink-0 rounded-full bg-[color:var(--color-accent)]"></span>
						<span>Design the systems behind AI products: prompts, tools, integrations, messaging, and operational flows.</span>
					</li>
					<li class="flex items-start gap-3">
						<span class="mt-3 h-1.5 w-1.5 shrink-0 rounded-full bg-[color:var(--color-accent)]"></span>
						<span>Turn complex AI behavior into clean product interfaces teams and customers can actually use.</span>
					</li>
				</ul>
			</section>

			<section class="mt-18 sm:mt-20">
				<div class="flex items-center justify-between gap-4">
					<p class="text-xs uppercase tracking-[0.28em] text-[color:var(--color-accent)]">Projects</p>
					<a
						class="text-sm text-[color:var(--color-ink-soft)] transition hover:text-[color:var(--color-ink)]"
						href="https://github.com/lucasscarioca"
						target="_blank"
						rel="noreferrer"
					>
						View all
					</a>
				</div>

				<div class="mt-6 border-t border-[color:var(--color-line)]">
					<a
						class="group flex flex-col gap-4 border-b border-[color:var(--color-line)] py-7 transition sm:flex-row sm:items-start sm:justify-between"
						href="https://github.com/lucasscarioca/lazycompass"
						target="_blank"
						rel="noreferrer"
						>
							<div class="max-w-2xl">
							<h2 class="text-2xl font-semibold tracking-[-0.04em] text-[color:var(--color-ink)] transition group-hover:text-[color:var(--color-accent)]">
								lazycompass
							</h2>
							<p class="mt-3 max-w-xl text-base leading-8 text-[color:var(--color-ink-soft)] transition group-hover:text-[color:var(--color-ink)]">
								Developer tool focused on operational clarity: faster MongoDB workflows, reusable queries, and less friction around day-to-day data work.
							</p>
							<p class="mt-3 text-sm text-[color:var(--color-ink-soft)]">
								Rust / CLI / MongoDB / Open source
							</p>
						</div>
						<span class="translate-x-0 text-sm text-[color:var(--color-ink-soft)] transition duration-200 group-hover:translate-x-1 group-hover:text-[color:var(--color-ink)]">
							Open
						</span>
					</a>
					<a
						class="group flex flex-col gap-4 border-b border-[color:var(--color-line)] py-7 transition sm:flex-row sm:items-start sm:justify-between"
						href="https://github.com/lucasscarioca/gram-agent"
						target="_blank"
						rel="noreferrer"
					>
						<div class="max-w-2xl">
							<h2 class="text-2xl font-semibold tracking-[-0.04em] text-[color:var(--color-ink)] transition group-hover:text-[color:var(--color-accent)]">
								gram-agent
							</h2>
							<p class="mt-3 max-w-xl text-base leading-8 text-[color:var(--color-ink-soft)] transition group-hover:text-[color:var(--color-ink)]">
								Starter for shipping Telegram-based AI agents on Cloudflare Workers, with a clean foundation for tools, messaging, and automation.
							</p>
							<p class="mt-3 text-sm text-[color:var(--color-ink-soft)]">
								TypeScript / Telegram / Cloudflare Workers / Open source
							</p>
						</div>
						<span class="translate-x-0 text-sm text-[color:var(--color-ink-soft)] transition duration-200 group-hover:translate-x-1 group-hover:text-[color:var(--color-ink)]">
							Open
						</span>
					</a>
				</div>
			</section>

			<footer class="mt-16 flex flex-col gap-3 border-t border-[color:var(--color-line)] pt-5 text-sm text-[color:var(--color-ink-soft)] sm:flex-row sm:items-center sm:justify-between">
				<p>Fortaleza, Brazil</p>
				<a
					class="transition hover:text-[color:var(--color-ink)]"
					href="mailto:lucascarioca97@gmail.com"
				>
					Contact me
				</a>
			</footer>
		</div>
	</main>
</Layout>
